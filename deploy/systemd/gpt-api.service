[Unit]
Description=GPT API service
After=network.target

[Service]
Type=simple
User=user
WorkingDirectory=/home/user/gpt-api
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/user/gpt-api/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8020
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
